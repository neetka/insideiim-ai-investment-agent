# LLM Provider Configuration
# Choose between 'gemini' or 'openai'
LLM_PROVIDER=gemini

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Web Research API (Tavily)
# Get a key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Recent News API (NewsAPI or Tavily Search API key can be reused)
# Get a key at https://newsapi.org (optional, if empty Tavily will be used as fallback)
NEWS_API_KEY=your_news_api_key_here
